# ════════════════════════════════════════════════════════════════
#  SolveLicita — .gitignore
#  Atualizado para estrutura: src/{collectors,processors,scorers,
#  engine,utils} | app/ | api/ | tests/ | docs/ | data/
# ════════════════════════════════════════════════════════════════


# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
MANIFEST
build/
dist/
wheels/
share/python-wheels/


# ── Ambientes virtuais ────────────────────────────────────────────
.env
.envrc
.venv
venv/
env/
ENV/
venv.bak/
env.bak/


# ── Ferramentas de empacotamento ──────────────────────────────────
.pdm-python
.pdm-build/
.pixi/
__pypackages__/
pip-log.txt
pip-delete-this-directory.txt
.pypirc


# ── Testes e cobertura ────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
nosetests.xml
.hypothesis/


# ── Tipagem e linting ─────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/


# ── IDEs e editores ───────────────────────────────────────────────
.vscode/
# .idea/           ← descomente se não usa JetBrains no time
.spyderproject
.spyproject
.ropeproject
.cursorignore
.cursorindexingignore
.abstra/


# ── Jupyter / notebooks ───────────────────────────────────────────
.ipynb_checkpoints
profile_default/
ipython_config.py
__marimo__/


# ── Docs gerados ──────────────────────────────────────────────────
docs/_build/
/site


# ════════════════════════════════════════════════════════════════
#  DADOS — regras específicas do projeto
# ════════════════════════════════════════════════════════════════

# Raw: tudo ignorado (arquivos grandes de snapshots)
data/raw/**/*.csv
data/raw/**/*.json
data/raw/**/*.jsonl
data/raw/**/*.zip
data/raw/**/*.parquet

# Processed: ignorado por padrão (gerado pelo pipeline)
data/processed/*.csv
data/processed/*.parquet

# Outputs: ignorado por padrão
data/outputs/*.csv

# Exceções: score final vai pro git (é o artefato público do projeto)
!data/outputs/score_municipios_pb.csv
!data/processed/municipios_pb_tabela.csv
!data/outputs/score_municipios_pb_pncp.csv

# devcontainer
.devcontainer/

# Score duplicado em processed
data/processed/score_municipios_pb.csv

# GeoJSON do app: pequeno o suficiente para versionar
# app/data/pb_score.geojson   ← não ignorado (641 KB, aceitável)


# ════════════════════════════════════════════════════════════════
#  SCRIPTS TEMPORÁRIOS / DIAGNÓSTICO
# ════════════════════════════════════════════════════════════════
diagnostico*.py
teste*.py
verificar_*.py
baixar_*.py
achar_urls_*.py
treewriter.py
verifica.py


# ── Misc ──────────────────────────────────────────────────────────
*.log
*.manifest
*.spec
*.mo
*.pot
*.sage.py
celerybeat-schedule
celerybeat.pid
db.sqlite3
db.sqlite3-journal
